---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
}
const appUrl = import.meta.env.APP_URL || "https://hackathon.madura.dev";

const {
  title = "Hackathon SEMESTA 8 - SEVIMA x MaduraDev",
  description = "Ikuti Hackathon SEMESTA 8 Sevima × MaduraDev. Kompetisi coding sprint individual 8 jam berhadiah Beasiswa S1 BINUS & Peluang Kerja di SEVIMA.",
  url = appUrl,
  image = "/og-image.jpg",
} = Astro.props;

// Generative Engine (GEO) & Answer Engine (AEO) Structured Data
const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Hackathon SEMESTA 8",
  "description": description,
  "startDate": "2026-09-05T08:00:00+07:00",
  "endDate": "2026-10-28T17:00:00+07:00",
  "eventAttendanceMode": "https://schema.org/MixedEventAttendanceMode",
  "eventStatus": "https://schema.org/EventScheduled",
  "location": {
    "@type": "Place",
    "name": "Kantor SEVIMA HQ",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Jl. Medokan Asri Barat No.3",
      "addressLocality": "Surabaya",
      "addressRegion": "Jawa Timur",
      "postalCode": "60293",
      "addressCountry": "ID"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "MaduraDev",
    "url": "https://madura.dev"
  },
  "sponsor": {
    "@type": "Company",
    "name": "SEVIMA",
    "url": "https://sevima.com",
    "sameAs": ["https://www.facebook.com/sevima/", "https://www.linkedin.com/company/sevima/"]
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "IDR",
    "availability": "https://schema.org/InStock",
    "validFrom": "2026-06-22",
    "url": "https://maukuliah.id"
  }
};
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico"/>
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050509" />
    <link rel="canonical" href={url} />

    <!-- Robots Meta -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Hackathon SEMESTA 8" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Event Schema JSON-LD (GEO & AEO optimization) -->
    <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />
  </head>
  <body>
    <slot />

    <!-- GSAP via CDN (using is:inline to prevent Vite bundling and ensure correct global loading) -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
    <script is:inline>
      // Reduced motion check — run early before GSAP loads
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.classList.add("reduced-motion");
      }
    </script>
    <script is:inline src="/animations.js" defer></script>
  </body>
</html>
