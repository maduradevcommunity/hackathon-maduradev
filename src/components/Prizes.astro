---
// Prizes.astro
const grandPrize = {
  label: "ULTIMATE_REWARD // GRAND_PRIZE",
  nominal: "Beasiswa S1 BINUS & Kontrak Kerja SEVIMA",
  glow: "rgba(0, 255, 102, 0.2)",
  border: "border-terminal-green/50",
  textClass: "text-terminal-green",
  badge: "bg-terminal-green/10 text-terminal-green border-terminal-green/30",
  benefits: [
    "Beasiswa Pendidikan S1 di BINUS University",
    "Peluang Kerja / Karir langsung di SEVIMA",
    "Akomodasi & Tiket Grand Final di Kantor SEVIMA",
    "E-Certificate Resmi SEVIMA",
    "Networking eksklusif dengan C-level SEVIMA"
  ],
  indicator: "[ SYSTEM_GRAND_FINAL_CORE ]",
};
---

<section id="prizes" class="relative py-24 md:py-32 px-4 border-t border-dark-border/40 tech-stripes">
  <div class="max-w-4xl mx-auto">
    <!-- Header Block -->
    <div data-reveal="up" class="text-left border-l-2 border-terminal-green pl-6 max-w-3xl mb-20 font-mono">
      <p class="text-xs uppercase tracking-widest text-terminal-green mb-2">// RESOURCE_POOL: GRAND_REWARD.json</p>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-tight text-text-primary uppercase">
        Grand Prize & <span class="text-transparent bg-clip-text bg-gradient-to-r from-terminal-green to-terminal-cyan">Career Path</span>
      </h2>
      <p class="mt-4 text-sm text-text-muted max-w-xl font-sans normal-case">
        Grand Finalis akan diundang langsung untuk mengikuti sesi final di Kantor SEVIMA, memperebutkan Beasiswa Pendidikan S1 BINUS University dan kontrak kerja eksklusif di SEVIMA.
      </p>
    </div>

    <!-- Prize server blades (centered single card layout) -->
    <div class="max-w-2xl mx-auto font-mono">
      <div class="prize-card w-full">
        <div
          class={`code-card rounded bg-dark-surface/90 border ${grandPrize.border} p-6 sm:p-10 text-left hover:scale-[1.01] transition-all duration-300 relative overflow-hidden`}
          style={`box-shadow: 0 15px 50px -15px ${grandPrize.glow}`}
        >
          <!-- Neon scanline decoration -->
          <div class="absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-transparent via-terminal-green to-transparent opacity-75"></div>

          <!-- Hardware tag -->
          <div class="flex items-center justify-between text-[10px] text-text-muted border-b border-dark-border pb-4 mb-6">
            <span>{grandPrize.indicator}</span>
            <span class={grandPrize.textClass}>LIVE FINAL @ SEVIMA HQ</span>
          </div>

          <!-- Title object -->
          <div class="space-y-2 mb-8">
            <span class={`inline-block px-3 py-1 rounded text-[11px] font-bold uppercase tracking-wider border ${grandPrize.badge}`}>
              {grandPrize.label}
            </span>
            <p class="text-xs text-text-muted mt-3">// REWARD_ALLOCATION_VALUE</p>
            <h3 class={`text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-tight leading-tight text-transparent bg-clip-text bg-gradient-to-r from-white via-text-primary to-terminal-green`}>
              {grandPrize.nominal}
            </h3>
          </div>

          <!-- Benefits JSON Mock -->
          <div class="border-t border-dark-border/40 pt-6 space-y-4">
            <p class="text-xs text-text-muted font-mono">// package_benefits = [</p>
            <div class="space-y-3 pl-4">
              {grandPrize.benefits.map((b) => (
                <div class="flex items-start gap-3 text-sm">
                  <span class="text-terminal-green">"✔"</span>
                  <span class="text-text-muted leading-relaxed font-sans">{b},</span>
                </div>
              ))}
            </div>
            <p class="text-xs text-text-muted font-mono">]</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Note footer -->
    <p data-reveal="up" class="text-center text-[10px] text-text-muted mt-16 font-mono uppercase tracking-wider">
      * system_notice: Transportasi dan akomodasi finalis ke kantor SEVIMA ditanggung sepenuhnya oleh panitia.
    </p>
  </div>
</section>

